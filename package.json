{
  "name": "teddy-client-manager-kamilaalves",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:web": "npx vite front-end --config front-end/vite.config.mts",
    "build:web": "npx vite build front-end --config front-end/vite.config.mts",
    "lint:web": "npx eslint front-end/src --ext .ts,.tsx",
    "typecheck:web": "npx tsc -p front-end/tsconfig.json --noEmit",
    "test:web": "npx vitest run --config front-end/vite.config.mts",
    "test:web:coverage": "npx vitest run --config front-end/vite.config.mts --coverage",
    "lint:api": "npx eslint back-end/src --ext .ts",
    "typecheck:api": "npx tsc -p back-end/tsconfig.app.json --noEmit",
    "build:api": "npx tsc -p back-end/tsconfig.app.json",
    "migration:run": "npm run build:api && npx typeorm -d back-end/dist/back-end/migrations/data-source.js migration:run",
    "migration:revert": "npm run build:api && npx typeorm -d back-end/dist/back-end/migrations/data-source.js migration:revert",
    "migration:show": "npm run build:api && npx typeorm -d back-end/dist/back-end/migrations/data-source.js migration:show",
    "test:api": "npx jest --config back-end/jest.config.cts --runInBand",
    "test:api:coverage": "npx jest --config back-end/jest.config.cts --runInBand --coverage",
    "start:api": "node -r ./back-end/dist/back-end/src/telemetry.js back-end/dist/back-end/src/main.js",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "lint": "npx nx run-many --target=lint --all",
    "format": "npx prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "npx prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.6.3",
    "@nx/eslint-plugin": "22.6.3",
    "@nx/jest": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/react": "^22.6.3",
    "@nx/vite": "22.6.3",
    "@nx/vitest": "22.6.3",
    "@nx/webpack": "22.6.3",
    "@playwright/test": "^1.58.2",
    "@rollup/wasm-node": "4.60.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "~4.0.0",
    "@vitest/ui": "~4.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jsdom": "~22.1.0",
    "lint-staged": "^16.4.0",
    "nx": "22.6.3",
    "patch-package": "^8.0.1",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.0.0"
  },
  "nx": {},
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  }
}
